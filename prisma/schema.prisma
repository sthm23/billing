// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

/**
 * =======================
 * ENUMS
 * =======================
 */
enum UserRole {
  ADMIN
  OWNER
  USER
}

enum UserType {
  CUSTOMER
  STAFF
}

enum StaffRole {
  OWNER
  SELLER
  MANAGER
  CASHIER
  WAREHOUSE
}

enum StockMovementType {
  IN
  OUT
}

enum StockMovementReason {
  PURCHASE
  SALE
  ADJUSTMENT
}

enum OrderStatus {
  CREATED
  COMPLETED
  DEBT
  CANCELLED
  HOLD
}

enum PaymentType {
  CASH
  CARD
  DEBT
  INSTALLMENT
}

enum OrderChannel {
  POS
  ONLINE
}

enum DeliveryStatus {
  PENDING
  IN_TRANSIT
  DELIVERED
  CANCELLED
}

enum DeliveryType {
  COURIER
  PICKUP
}

enum AttributeType {
  STRING
  NUMBER
  BOOLEAN
}

/**
 * =======================
 * AUTH & USERS
 * =======================
 */

model User {
  id        String   @id @default(uuid())
  fullName  String
  phone     String   @unique
  role      UserRole @default(USER)
  type      UserType
  createdAt DateTime @default(now())

  auth            AuthAccount?
  staff           Staff?
  orders          Order[]          @relation("CustomerOrders")
  refreshSessions RefreshSession[]
  stores          Store[] //created stores by this auth account
  staffOrders     Order[]          @relation("StaffOrders")
  payments        Payment[]        @relation("StaffOrders")

  @@map("users")
}

model AuthAccount {
  id           String   @id @default(uuid())
  userId       String   @unique
  login        String   @unique // e.g. email or username or phone
  passwordHash String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("auth_accounts")
}

model RefreshSession {
  id          String   @id @default(uuid())
  userId      String
  refreshHash String
  userAgent   String? // браузер / устройство
  ip          String?
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  isRevoked   Boolean  @default(false) // когда сессия была отозвана

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("refresh_sessions")
}

/**
 * =======================
 * STORES & STAFF
 * =======================
 */

model Store {
  id        String   @id @default(uuid())
  name      String
  ownerId   String
  createdAt DateTime @default(now())

  createdBy String // admin auth account id
  creator   User   @relation(fields: [createdBy], references: [id])

  warehouse Warehouse?
  staff     Staff[]
  products  Product[]
  orders    Order[]

  categories CategoriesOnStore[]
  brands     BrandsOnStore[]
  attributes AttributeOnStore[]

  @@map("stores")
}

model Staff {
  id        String    @id @default(uuid())
  userId    String    @unique
  storeId   String
  role      StaffRole
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())

  user  User  @relation(fields: [userId], references: [id])
  store Store @relation(fields: [storeId], references: [id])

  warehouse  Warehouse?      @relation(fields: [warehouseId], references: [id])
  stockMoves StockMovement[]

  warehouseId String?

  @@index([storeId])
  @@map("staff")
}

/**
 * =======================
 * WAREHOUSES
 * =======================
 */

model Warehouse {
  id       String  @id @default(uuid())
  storeId  String  @unique
  name     String
  isActive Boolean @default(true)

  store          Store           @relation(fields: [storeId], references: [id])
  inventory      Inventory[]
  orders         Order[]
  stockMovements StockMovement[]
  staffs         Staff[]
  createdAt      DateTime        @default(now())

  @@map("warehouses")
}

/**
 * =======================
 * PRODUCTS & VARIANTS
 * =======================
 */

model Brand {
  id   String @id @default(uuid())
  name String @unique

  stores   BrandsOnStore[]
  products Product[]

  @@map("brands")
}

model ProductImage {
  id        String  @id @default(uuid())
  productId String
  url       String
  isMain    Boolean @default(false)
  order     Int     @default(0)

  product Product @relation(fields: [productId], references: [id])

  @@index([productId, isMain])
  @@map("product_images")
}

model Tag {
  id     String     @id @default(uuid())
  name   String
  values TagValue[] // например "latex", "cotton" для тега "material"

  @@unique([name])
  @@map("tags")
}

model TagValue {
  id    String @id @default(uuid())
  tagId String
  value String

  tag     Tag               @relation(fields: [tagId], references: [id])
  product ProductTagValue[]

  @@unique([tagId, value])
  @@map("tag_values")
}

model ProductTagValue {
  productId  String
  tagValueId String

  product Product  @relation(fields: [productId], references: [id])
  value   TagValue @relation(fields: [tagValueId], references: [id])

  @@id([productId, tagValueId])
  @@map("product_tag_values")
}

model Product {
  id          String   @id @default(uuid())
  storeId     String
  name        String
  categoryId  String?
  brandId     String?
  description String?
  isArchived  Boolean  @default(false)
  createdAt   DateTime @default(now())

  store      Store              @relation(fields: [storeId], references: [id])
  category   Category?          @relation(fields: [categoryId], references: [id])
  brand      Brand?             @relation(fields: [brandId], references: [id])
  images     ProductImage[]
  variants   ProductVariant[]
  attributes ProductAttribute[]
  tags       ProductTagValue[]

  @@index([storeId])
  @@index([categoryId])
  @@index([brandId])
  @@map("products")
}

model ProductVariant {
  id        String  @id @default(uuid())
  productId String
  sku       String // ску будет уникален в пределах магазина
  barCode   String?
  price     Decimal
  storeId   String // это для быстрого поиска уникального SKU в пределах магазина

  product   Product     @relation(fields: [productId], references: [id])
  inventory Inventory[]

  orderItems     OrderItem[]
  stockMovements StockMovement[]
  attributes     VariantAttributeValue[]

  @@unique([storeId, sku])
  @@unique([storeId, barCode])
  @@index([productId])
  @@map("product_variants")
}

/**
 * =======================
 * INVENTORY
 * =======================
 */

model Inventory {
  id          String @id @default(uuid())
  warehouseId String
  variantId   String
  quantity    Int

  warehouse Warehouse      @relation(fields: [warehouseId], references: [id])
  variant   ProductVariant @relation(fields: [variantId], references: [id])

  @@unique([warehouseId, variantId])
  @@map("inventories")
}

/**
 * складские движения приход/расход
 * =======================
 * STOCK MOVEMENTS
 * =======================
 */
model StockMovement {
  id          String              @id @default(uuid())
  variantId   String
  warehouseId String
  type        StockMovementType
  reason      StockMovementReason
  quantity    Int
  unitCost    Decimal? // только для IN себестоимость
  createdById String
  createdAt   DateTime            @default(now())

  variant   ProductVariant @relation(fields: [variantId], references: [id])
  warehouse Warehouse      @relation(fields: [warehouseId], references: [id])
  createdBy Staff          @relation(fields: [createdById], references: [id])

  @@index([warehouseId, createdAt])
  @@index([variantId, createdAt])
  @@map("stock_movements")
}

/**
 * =======================
 * CATALOG
 * =======================
 */

model Category {
  id       String  @id @default(uuid())
  name     String  @unique
  parentId String?

  parent   Category?           @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[]          @relation("CategoryTree")
  products Product[]
  store    CategoriesOnStore[]

  @@index([parentId])
  @@map("categories")
}

/**
 * =======================
 * ATTRIBUTES (FILTERS)
 * =======================
 */

model Attribute {
  id   String        @id @default(uuid())
  name String        @unique
  type AttributeType

  values AttributeValue[]

  store   AttributeOnStore[]
  product ProductAttribute[]

  @@map("attributes")
}

model AttributeValue {
  id          String @id @default(uuid())
  attributeId String

  valueString String?
  valueNumber Decimal?
  valueBool   Boolean?

  attribute Attribute               @relation(fields: [attributeId], references: [id])
  variant   VariantAttributeValue[]

  @@unique([attributeId, valueString, valueNumber, valueBool])
}

model ProductAttribute {
  productId   String
  attributeId String

  product   Product   @relation(fields: [productId], references: [id])
  attribute Attribute @relation(fields: [attributeId], references: [id])

  @@id([productId, attributeId])
  @@map("product_attributes")
}

model VariantAttributeValue {
  variantId        String
  attributeValueId String

  variant ProductVariant @relation(fields: [variantId], references: [id])
  value   AttributeValue @relation(fields: [attributeValueId], references: [id])

  @@id([variantId, attributeValueId])
  @@map("variant_attribute_values")
}

model CategoriesOnStore {
  store      Store    @relation(fields: [storeId], references: [id])
  storeId    String
  category   Category @relation(fields: [categoryId], references: [id])
  categoryId String

  @@id([storeId, categoryId])
  @@map("categories_on_stores")
}

model BrandsOnStore {
  store   Store  @relation(fields: [storeId], references: [id])
  storeId String
  brand   Brand  @relation(fields: [brandId], references: [id])
  brandId String

  @@id([storeId, brandId])
  @@map("brands_on_stores")
}

model AttributeOnStore {
  store       Store     @relation(fields: [storeId], references: [id])
  storeId     String
  attribute   Attribute @relation(fields: [attributeId], references: [id])
  attributeId String

  @@id([storeId, attributeId])
  @@map("attributes_on_stores")
}

/**
 * =======================
 * ORDERS & SALES
 * =======================
 */

model Order {
  id          String       @id @default(uuid())
  storeId     String
  warehouseId String
  cashierId   String
  customerId  String?
  channel     OrderChannel
  status      OrderStatus
  totalAmount Decimal
  paidAmount  Decimal      @default(0)
  createdAt   DateTime     @default(now())

  store     Store     @relation(fields: [storeId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
  cashier   User      @relation("StaffOrders", fields: [cashierId], references: [id])
  customer  User?     @relation("CustomerOrders", fields: [customerId], references: [id])

  items    OrderItem[]
  payments Payment[]
  delivery Delivery?

  @@index([storeId, createdAt])
  @@index([warehouseId, createdAt])
  @@map("orders")
}

model OrderItem {
  id          String  @id @default(uuid())
  orderId     String
  variantId   String
  quantity    Int
  retailPrice Decimal // Розничная цена на момент продажи, может отличаться от текущей цены в каталоге
  sale        Decimal @default(0) // Скидка на момент продажи
  costAtSale  Decimal // За сколько закупили

  order   Order          @relation(fields: [orderId], references: [id])
  variant ProductVariant @relation(fields: [variantId], references: [id])

  @@index([orderId])
  @@index([variantId])
  @@map("order_items")
}

/**
 * =======================
 * PAYMENTS
 * =======================
 */

model Payment {
  id        String      @id @default(uuid())
  orderId   String
  type      PaymentType
  amount    Decimal
  paidAt    DateTime?
  createdAt DateTime    @default(now())
  createdBy String

  cashier User  @relation("StaffOrders", fields: [createdBy], references: [id])
  order   Order @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@map("payments")
}

/**
 * =======================
 * DELIVERY
 * =======================
 */

model Delivery {
  id          String         @id @default(uuid())
  orderId     String         @unique
  type        DeliveryType   @default(PICKUP)
  address     String?
  phone       String?
  fee         Decimal        @default(0)
  status      DeliveryStatus @default(PENDING)
  shippedAt   DateTime?
  deliveredAt DateTime?

  order Order @relation(fields: [orderId], references: [id])

  @@map("deliveries")
}
