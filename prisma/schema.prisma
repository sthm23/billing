/**
 * =======================
 * ENUMS
 * =======================
 */

enum UserRole {
  ADMIN
  OWNER
  USER
}

enum UserType {
  CUSTOMER
  STAFF
}

enum StaffRole {
  OWNER
  SELLER
  MANAGER
  CASHIER
  WAREHOUSE
}

enum StockMovementType {
  IN
  OUT
}

enum StockMovementReason {
  PURCHASE
  SALE
  ADJUSTMENT
  RETURN
}

enum OrderStatus {
  CREATED
  COMPLETED
  DEBT
  CANCELLED
  HOLD
  REFUNDED
}

enum ReturnOrderStatus {
  DEBT
  CREDIT
  COMPLETED
}

enum PaymentType {
  CASH
  CARD
  DEBT
  INSTALLMENT
}

enum OrderChannel {
  POS
  ONLINE
}

enum DeliveryStatus {
  PENDING
  IN_TRANSIT
  DELIVERED
  CANCELLED
}

enum DeliveryType {
  COURIER
  PICKUP
}

enum AttributeType {
  STRING
  NUMBER
  BOOLEAN
}
